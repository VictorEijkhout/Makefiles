BUILDSYSTEM = cmake
HASBIN=1
PREFIXPATHSET = 1
PKGCONFIGLIB = pkgconfig
DEPENDSONCURRENT = hdf5
LINKLIB64toLIB = 1
CPTOINSTALLDIR = examples

MODE = seq
MODULES += hdf5
NETCDF_PARALLEL = OFF

# -D CMAKE_C_FLAGS='-DHAVE_STDIO_H -DHAVE_STDLIB_H'
CMAKEFLAGS = \
    -D HAVE_STDINT_H=OFF \
    -D NETCDF_ENABLE_PARALLEL4=${NETCDF_PARALLEL} \
    -D ENABLE_PARALLEL_TESTS=OFF \
    -D NETCDF_ENABLE_HDF5=ON \
    -D ENABLE_NETCDF_4=ON \
    -D ENABLE_DAP=ON \
    ${CMAKEFORTRANFLAGS}
