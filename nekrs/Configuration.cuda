################################################################
####
#### Makefile for NekRS installation
#### gpu version
####
################################################################

PACKAGE = nekrs
MODE = mpi

include Configuration.basic

# adios problem to be fixed in 26.1
# https://github.com/Nek5000/nekRS/issues/704
MODULES = adios2 cuda

# see Configuration.gpu
USECUDA = ON
INSTALLVARIANT = gpu 
MODULEVERSIONEXTRA = gpu

include Configuration.common

DEPENDSON = adios2 cuda
