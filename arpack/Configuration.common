MODULES = eigen blaslapack
# arpack explicitly loads 3.3
# eigen/5 needs c++14 support
# which is not propagated from arpack

BUILDSYSTEM = cmake
USEEIGEN = ON
SYSTEM==vista COMPILER==nvidia USEEIGEN = OFF

CMAKEFLAGS = \
    -D EXAMPLES=ON -D ICB=ON \
    -D EIGEN=${USEEIGEN} \
    -D MPI=${ARPACKPARALLEL} \
    -D BLAS_LIBRARIES='${BLASLAPACK_LIBS}' \
    -D LAPACK_LIBRARIES='${BLASLAPACK_LIBS}'
PKGCONFIGLIB = pkgconfig
PREFIXPATHSET = 1
CPTOINSTALLDIR = EXAMPLES
